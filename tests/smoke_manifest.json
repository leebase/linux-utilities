{
  "steps": [
    {
      "name": "start helper",
      "path": "tests/smoke_start.py",
      "command": ["python3", "tests/smoke_start.py"]
    },
    {
      "name": "smoke script",
      "path": "scripts/smoke.sh",
      "command": ["bash", "scripts/smoke.sh"]
    },
    {
      "name": "deterministic fixture suite",
      "path": "tests/test_sysdiff_fixture.sh",
      "command": ["bash", "tests/test_sysdiff_fixture.sh"]
    },
    {
      "name": "smoke check script",
      "path": "tests/check_sysdiff_smoke.py",
      "command": ["python3", "tests/check_sysdiff_smoke.py"]
    }
  ],
  "start_command": ["python3", "tests/smoke_start.py"],
  "check_command": ["python3", "tests/check_sysdiff_smoke.py"],
  "startup_delay_seconds": 0,
  "startup_timeout_seconds": 10,
  "poll_interval_seconds": 0.25,
  "check_timeout_seconds": 30
}
